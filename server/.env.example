# Copy this file to .env and fill in your real keys
# Add these as Environment Variables in Render dashboard

GEMINI_API_KEY=your_gemini_key_here
WEATHER_API_KEY=your_weatherapi_key_here
OPENAQ_API_KEY=your_openaq_key_here
GEODB_API_KEY=your_geodb_key_here

# Set this to your Vercel frontend URL after deploying frontend
FRONTEND_URL=https://your-project.vercel.app
